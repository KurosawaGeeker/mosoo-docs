{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mosoo API",
  "description": "Developer documentation for calling published Mosoo Agents.",
  "colors": {
    "primary": "#086030"
  },
  "logo": {
    "light": "/images/brand/logo-api-onlight.svg",
    "dark": "/images/brand/logo-api-ondark.svg"
  },
  "favicon": "/images/brand/favicon.svg",
  "api": {
    "examples": {
      "prefill": true
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "tabs": [
          {
            "tab": "API",
            "icon": "code",
            "groups": [
              {
                "group": "Start",
                "pages": ["index", "quickstart", "auth-and-access"]
              },
              {
                "group": "API Reference",
                "openapi": "mosoo-openapi.en.generated.json"
              }
            ]
          },
          {
            "tab": "CLI",
            "icon": "terminal",
            "groups": [
              {
                "group": "CLI",
                "pages": ["cli/overview"]
              }
            ]
          }
        ]
      },
      {
        "language": "zh-Hans",
        "tabs": [
          {
            "tab": "API",
            "icon": "code",
            "groups": [
              {
                "group": "开始",
                "pages": ["zh-Hans/index", "zh-Hans/quickstart", "zh-Hans/auth-and-access"]
              },
              {
                "group": "API Reference",
                "openapi": "mosoo-openapi.zh-Hans.generated.json"
              }
            ]
          },
          {
            "tab": "CLI",
            "icon": "terminal",
            "groups": [
              {
                "group": "CLI",
                "pages": ["zh-Hans/cli/overview"]
              }
            ]
          }
        ]
      }
    ]
  }
}
