                "$ref": "#/components/schemas/ThreadAttributedUser"
              },
              {
                "type": "null"
              }
            ]
          },
          "client_external_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_by": {
            "$ref": "#/components/schemas/ThreadCaller"
          },
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "pet",
              "cattle"
            ]
          },
          "last_run_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "const": "api"
          },
          "status": {
            "enum": [
              "IDLE",
              "RUNNING",
